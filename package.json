{
  "name": "@omnixys/logger",
  "version": "3.0.0",
  "description": "A NestJS logger module for microservices, providing structured logging and integration with various log transports.",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./token": {
      "types": "./dist/token.d.ts",
      "import": "./dist/token.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "test:types": "pnpm run build && tsc -p tsconfig.type-tests.json",
    "clean": "rimraf dist",
    "patch": "pnpm version patch",
    "release": "semantic-release",
    "dev": "tsc -w",
    "link": "pnpm link --global"
  },
  "keywords": [
    "omnixys",
    "logger",
    "microservices"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.4.2",
    "@nestjs/core": "^11.1.17",
    "@omnixys/context": "^3.0.0",
    "@omnixys/contracts": "^3.0.0",
    "@omnixys/observability": "^3.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@swc/core": "^1.15.21",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.17",
    "@omnixys/context": "^2.0.0",
    "@omnixys/contracts": "^2.0.0",
    "@omnixys/observability": "^2.0.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.2"
  }
}
